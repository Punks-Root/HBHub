# Copia este archivo a .env y añade tus claves
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# URL pública donde estará el servidor (ej: https://mi-dominio.com)
PUBLIC_URL=http://localhost:4242
# SMTP para enviar emails (opcional: usar SendGrid SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=secret
FROM_EMAIL="HB Hub" <no-reply@example.com>
